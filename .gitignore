# Secrets — never commit
.env

# Python
.venv/
__pycache__/
*.pyc
*.pyo

# Node
node_modules/

# Rendered images — uploaded to GitHub Pages separately, not tracked in git
generated_images/

# Transient pipeline state — regenerated each run
trend_candidates.json
